# Copy to `.env.local` for local development. Never commit real secrets.

# Resend — create at https://resend.com/api-keys
RESEND_API_KEY=

# From address. Must be on a domain verified in Resend (SPF/DKIM/DMARC).
# Until DNS is configured, omit this to use the Resend onboarding sender.
# Production target (after dashboard verification):
#   hello@lookingglass.coalescencelabs.app
SUBMIT_FROM_EMAIL=

# Inbox that receives submissions from `/about`
SUBMIT_TO_EMAIL=coalescencelabs@gmail.com
